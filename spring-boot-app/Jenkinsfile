pipeline {
    agent {
        docker {
            image 'keerthan04/jenkins-app:v1'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }
    stages {
        stage('Build') {
            steps{
                sh 'cd spring-boot-app && mvn clean package -DskipTests'
            }
        }
        stage('Test') {
            steps {
                sh 'cd spring-boot-app && mvn test'
            }
        }
        stage('Static code analysis') {
            environment {
                SONAR_URL = 'http://sonarqube:9000'
            }
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_TOKEN')]) {
                    sh "cd spring-boot-app && mvn sonar:sonar -Dsonar.host.url=${SONAR_URL} -Dsonar.login=${SONAR_TOKEN}"
                }
            }
        }
    }
}