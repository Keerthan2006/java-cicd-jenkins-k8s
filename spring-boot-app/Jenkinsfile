pipeline {

    agent {
        docker {
            image 'keerthan04/jenkins-agent:01'
            args '--network spring-boot-app_jenkins-sonar -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }
    environment {
        DOCKER_IMAGE = 'keerthan04/java-spring-app'
        TAG_NAME = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('spring-boot-app') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }
        stage('Test') {
            steps{
                dir('spring-boot-app') {
                    sh 'mvn test'
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir('spring-boot-app') {
                    withSonarQubeEnv('sonar') {
                        sh 'mvn sonar:sonar'
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('spring-boot-app') {
                    sh "docker build -t ${DOCKER_IMAGE}:${TAG_NAME} ."
                }
            }
        }
        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )
                ])
                {
                    sh "echo ${DOCKER_PASSWORD} | docker login -u ${DOCKER_USERNAME} --password-stdin"
                    sh "docker push ${DOCKER_IMAGE}:${TAG_NAME}"
                }
            }
        }
        stage('Update Helm Values') {
            steps {
                sed -i "s/tag:.*/tag: ${BUILD_NUMBER}/" helm/helm-k8s-manifests/values.yaml
            }
        }
        stage('Commit changes to Github'){
            steps{
                    withCredentials([usernamePassword(
                        credentialsId: 'github-app',
                        usernameVariable: 'GITHUB_USERNAME',
                        passwordVariable: 'GITHUB_TOKEN'
                    ),
                    string(credentialsId: 'mail-id', variable: 'GITHUB_EMAIL')
                    ])
                {
                    sh '''
                    git config --global user.name "${GITHUB_USERNAME}"
                    git config --global user.email "${GITHUB_EMAIL}"
                    git add helm/helm-k8s-manifests/values.yaml
                    git commit -m "Update Helm values with new image tag ${BUILD_NUMBER}"
                    git push https://${GITHUB_USERNAME}:${GITHUB_TOKEN}@github.com/${GITHUB_USERNAME}/java-cicd-jenkins-k8s.git HEAD:main
                    '''
                }
 
            }
        }

    }
}